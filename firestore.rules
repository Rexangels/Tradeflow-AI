rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, email, displayName, photoURL, role, createdAt
    //
    // Collection: agents
    // Fields: id, ownerId, name, type, rewardStyle, riskTolerance, holdingBehavior, createdAt
    //
    // Collection: backtests
    // Fields: id, ownerId, agentId, symbol, timeframe, totalProfit, drawdown, sharpeRatio, winRate, timestamp
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.ownerId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "danielyamaiphilips@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string && data.uid == request.auth.uid &&
             data.email is string && data.email.size() < 100;
    }

    function isValidAgent(data) {
      return data.keys().hasAll(['id', 'ownerId', 'name']) &&
             data.ownerId == request.auth.uid &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100;
    }

    function isValidBacktest(data) {
      return data.keys().hasAll(['id', 'ownerId', 'agentId']) &&
             data.ownerId == request.auth.uid;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == resource.data.role;
    }

    match /agents/{agentId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidAgent(request.resource.data);
      allow update: if isDocOwner() && isValidAgent(request.resource.data);
      allow delete: if isDocOwner();
    }

    match /backtests/{backtestId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidBacktest(request.resource.data);
      allow delete: if isDocOwner();
    }

    match /broker_keys/{keyId} {
      allow read, write: if isDocOwner() || isAdmin();
    }
  }
}
